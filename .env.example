# Gemini AI Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash

# Google Cloud TTS Configuration (optional)
VITE_GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Feature Flags
VITE_USE_MOCK_MANIFEST=false

# Ingestion backend (Render): lighter defaults to avoid OOM. Override if you need more.
# INGEST_MAX_FILES=120
# INGEST_MAX_TOTAL_BYTES=6291456
# INGEST_MAX_FILE_BYTES=524288
# INGEST_USE_ARCHIVE=true
