# Gemini API Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-3-pro-preview
VITE_GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Available models for REST API (choose one):
# - gemini-1.5-pro-latest (stable, most capable)
# - gemini-1.5-flash-latest (faster, cheaper)
# - gemini-2.0-flash-exp (experimental, latest features)
# - gemini-3-pro-preview (preview, best quality if enabled)
