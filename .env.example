# Gemini AI Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Use API model ID only (e.g. gemini-2.5-flash). See https://ai.google.dev/api/models
VITE_GEMINI_MODEL=gemini-2.5-flash

# Google Cloud TTS Configuration (optional)
VITE_GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# Feature Flags
VITE_USE_MOCK_MANIFEST=false

# Ingestion limits: cap how much of the repo is read (avoids OOM / timeouts).
# Defaults: 120 files, 6 MB total, 512 KB per file. Large repos (e.g. ever-co/ever-gauzy)
# will show many "Skipped Files" until you raise these (server/env only, not VITE_).
# INGEST_MAX_FILES=120
# INGEST_MAX_TOTAL_BYTES=6291456
# INGEST_MAX_FILE_BYTES=524288
# INGEST_USE_ARCHIVE=true
